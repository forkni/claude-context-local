# DSPy runs through your Claude Code subscription. Do NOT set ANTHROPIC_API_KEY.
# Setting ANTHROPIC_API_KEY causes the Claude CLI to use API billing instead of
# your Max plan, which would incur direct charges.
#
# Usage:
#   1. Copy this file to .env  →  cp env.example .env
#   2. Uncomment and fill in any lines you need.
#   3. Never commit .env  (it is already in .gitignore).

# Optional: long-lived subscription token for unattended/headless runs.
#   Generate with:  claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=

# Optional: override the model the DSPy backend uses.
# DSPY_LM_MODEL=claude-sonnet-4-6

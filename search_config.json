{
  "embedding": {
    "model_name": "Qwen/Qwen3-Embedding-0.6B",
    "dimension": 1024,
    "batch_size": 64,
    "query_cache_size": 128,
    "enable_import_context": true,
    "enable_class_context": true,
    "max_import_lines": 25,
    "max_class_signature_lines": 20,
    "enable_structural_header": true
  },
  "search_mode": {
    "default_mode": "hybrid",
    "enable_hybrid": true,
    "bm25_weight": 0.35,
    "dense_weight": 0.65,
    "bm25_k_parameter": 100,
    "bm25_use_stopwords": true,
    "bm25_use_stemming": true,
    "min_bm25_score": 0.1,
    "rrf_k_parameter": 100,
    "enable_result_reranking": true,
    "default_k": 4,
    "max_k": 50,
    "default_max_context_tokens": 0
  },
  "performance": {
    "use_parallel_search": true,
    "max_parallel_workers": 2,
    "enable_parallel_chunking": true,
    "max_chunking_workers": 8,
    "enable_entity_tracking": true,
    "prefer_gpu": true,
    "vram_limit_fraction": 0.8,
    "allow_ram_fallback": true,
    "enable_fp16": true,
    "prefer_bf16": true,
    "enable_dynamic_batch_size": true,
    "dynamic_batch_min": 16,
    "dynamic_batch_max": 64,
    "use_onnx": false,
    "onnx_gpu_mem_limit": true,
    "enable_auto_reindex": true,
    "max_index_age_minutes": 30.0
  },
  "multi_hop": {
    "enabled": true,
    "hop_count": 2,
    "expansion": 0.5,
    "initial_k_multiplier": 2.0,
    "multi_hop_mode": "hybrid",
    "edge_weights": null
  },
  "routing": {
    "multi_model_enabled": false,
    "default_model": "qwen3_0.6b",
    "multi_model_pool": "lightweight-speed"
  },
  "intent": {
    "enabled": true,
    "confidence_threshold": 0.4,
    "default_intent": "HYBRID",
    "log_classifications": true,
    "semantic_enabled": true,
    "semantic_weight": 0.3
  },
  "reranker": {
    "enabled": true,
    "model_name": "Alibaba-NLP/gte-reranker-modernbert-base",
    "top_k_candidates": 50,
    "min_vram_gb": 6.0,
    "batch_size": 16
  },
  "output": {
    "format": "ultra",
    "source_order_output": true
  },
  "chunking": {
    "min_chunk_tokens": 50,
    "max_merged_tokens": 1000,
    "enable_community_detection": true,
    "enable_community_merge": false,
    "community_resolution": 1.5,
    "max_phantom_degree": 20,
    "enable_large_node_splitting": true,
    "max_chunk_lines": 100,
    "token_estimation": "whitespace",
    "size_method": "tokens",
    "split_size_method": "characters",
    "max_split_chars": 3000,
    "enable_file_summaries": true,
    "enable_community_summaries": true,
    "enable_incremental_community_summaries": true,
    "incremental_community_redetect_threshold": 0.3,
    "sizing_mode": "adaptive",
    "adaptive_multiplier_max": 1.3,
    "adaptive_multiplier_min": 0.5,
    "max_complexity_cap": 30
  },
  "ego_graph": {
    "enabled": true,
    "k_hops": 2,
    "max_neighbors_per_hop": 10,
    "relation_types": null,
    "include_anchor": true,
    "deduplicate": true,
    "exclude_stdlib_imports": true,
    "exclude_third_party_imports": true,
    "edge_weights": {
      "calls": 1.0,
      "inherits": 0.9,
      "implements": 0.9,
      "overrides": 0.85,
      "uses_type": 0.7,
      "instantiates": 0.7,
      "decorates": 0.5,
      "raises": 0.4,
      "catches": 0.4,
      "imports": 0.3,
      "assigns_to": 0.5,
      "reads_from": 0.5,
      "defines_constant": 0.4,
      "defines_enum_member": 0.4,
      "defines_class_attr": 0.5,
      "defines_field": 0.5,
      "uses_constant": 0.4,
      "uses_default": 0.3,
      "uses_global": 0.3,
      "asserts_type": 0.4,
      "uses_context_manager": 0.4
    },
    "community_bounded": true,
    "cross_community_penalty": 0.6,
    "expansion_mode": "bfs",
    "ppr_alpha": 0.85,
    "min_similarity_threshold": 0.15
  },
  "parent_retrieval": {
    "enabled": false,
    "include_parent_content": true,
    "max_parents_per_result": 1
  },
  "graph_enhanced": {
    "centrality_method": "pagerank",
    "centrality_alpha": 0.2,
    "centrality_annotation": true,
    "centrality_reranking": true,
    "enable_size_normalization": true,
    "size_norm_target_lines": 200,
    "size_norm_alpha": 0.1,
    "centrality_bm25_boost": true,
    "centrality_boost_threshold": 0.02,
    "centrality_boost_factor": 5.0,
    "centrality_boost_cap": 0.15
  },
  "observability": {
    "enabled": false,
    "service_name": "claude-context-local",
    "exporter": "otlp",
    "otlp_endpoint": "http://localhost:4318",
    "sample_ratio": 1.0,
    "capture_query_text": false
  },
  "call_graph": {
    "resolvers": ["pyan", "libcst"],
    "lsp_enabled": true,
    "lsp_timeout_seconds": 30.0,
    "use_pyproject_toml": true,
    "min_confidence": 0.65
  }
}